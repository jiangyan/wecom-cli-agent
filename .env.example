# === WeCom Bot Configuration ===
# From WeCom admin console > Smart Robot > API Mode > Long Connection
WECOM_BOT_ID=your_bot_id
WECOM_SECRET=your_long_connection_secret

# === Welcome Message ===
WELCOME_MESSAGE=Hello! I'm the smart assistant, how can I help you?

# === AI Auto-Answer (optional) ===
# Set AI_ENABLED=true to enable AI-powered auto-replies
AI_ENABLED=false
ANTHROPIC_API_KEY=your_anthropic_api_key
AI_MODEL=claude-sonnet-4-6

# === Tool Calling ===
# Max rounds of tool calling per message (default 999 for testing)
MAX_ROUNDS=999
