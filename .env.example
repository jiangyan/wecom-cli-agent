# === WeCom Bot Configuration ===
# From WeCom admin console > Smart Robot > API Mode > Long Connection
WECOM_BOT_ID=your_bot_id
WECOM_SECRET=your_long_connection_secret

# === Welcome Message ===
WELCOME_MESSAGE=Hello! I'm the smart assistant, how can I help you?

# === AI Auto-Answer (optional) ===
# Set AI_ENABLED=true to enable AI-powered auto-replies
AI_ENABLED=false

# Provider is auto-detected from AI_MODEL:
#   gpt-*, o3*, o4*, codex* → OpenAI (Responses API)
#   claude-*, everything else → Anthropic (Messages API)
AI_MODEL=claude-sonnet-4-6

# Set the API key for your chosen provider:
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# OpenAI auth mode: "api_key" (default) or "chatgpt" (OAuth via ChatGPT subscription)
# For ChatGPT OAuth: run `npm run login` first, then set OPENAI_AUTH_MODE=chatgpt
OPENAI_AUTH_MODE=api_key

# === Tool Calling ===
# Max output tokens per response (default 16384)
MAX_TOKENS=16384
# Max rounds of tool calling per message (default 999)
MAX_ROUNDS=999

# === Conversation History ===
# Max estimated tokens of history to keep per session (default 100000)
MAX_HISTORY_TOKENS=100000
# Session TTL in minutes — history cleared after inactivity (default 60)
SESSION_TTL_MINUTES=60
